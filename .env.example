# WhatsApp Business API
WHATSAPP_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=156969910833816
WHATSAPP_BUSINESS_ACCOUNT_ID=162302063631080
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_WEBHOOK_VERIFICATION_TOKEN=your_verify_token

# Google Gemini (for AI voice)
GOOGLE_API_KEY=your_gemini_api_key

# OpenAI (for text chatbot)
OPENAI_API_KEY=your_openai_api_key

# Chatwoot Integration (forward messages to Chatwoot inbox)
CHATWOOT_WEBHOOK_URL=https://wapp.munipramansagar.net/webhooks/whatsapp/+916207292062

# n8n Integration (post-call/chat hooks)
N8N_CALL_HOOK_URL=https://workflow.munipramansagar.net/webhook/call-summary
N8N_CHAT_HOOK_URL=https://workflow.munipramansagar.net/webhook/chat-summary

# Razorpay (for order payments — optional)
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Dashboard Security
DASHBOARD_PASSWORD=your_secure_password
WEBHOOK_SECRET=your_webhook_secret

# Greetings Staff Page (separate login for greeting campaign staff)
GREETINGS_PASSWORD=your_greetings_password

# Rooms Staff Page (separate login for room allotment/confirmation staff)
ROOMS_PASSWORD=your_rooms_password

# AI Toggle (set to false to disable AI chatbot system-wide, can also toggle via dashboard API)
AI_ENABLED=true

# Marketing Messages API (MM Lite) — uses Meta's AI for better delivery of marketing templates
USE_MARKETING_API=true

# Server
PORT=7860
ENVIRONMENT=production

# Branding (white-label — customise for your organisation)
APP_NAME=Gunayatan WhatsApp Platform
APP_SHORT_NAME=Gunayatan WhatsApp
BUSINESS_NAME=Gunayatan
BUSINESS_SHORT=गुणायतन
BUSINESS_CITY=Shikharji
SUPPORT_PHONE=+91 99340 50345

# Campaign Rate Limiting (messages per minute)
CAMPAIGN_RATE_LIMIT=100

# MinIO / S3 Storage (optional — if not configured, media is not downloaded)
MINIO_ENDPOINT=https://minio.yourdomain.com
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET=whatsapp-media
MINIO_REGION=us-east-1
MEDIA_EXPIRY_DAYS=7

# Google Sheets Integration (for dharamshala room lookup — optional)
GOOGLE_SHEETS_CREDENTIALS_JSON=path/to/service-account.json
DHARAMSHALA_SHEET_ID=your_google_sheet_id

# --- Dues PDF campaign (per-recipient PDF attachment) ---
# Folder must be "Anyone with the link can view" so the API key can read it.
DUES_DRIVE_FOLDER_ID=1x_aEpV07-mQ04f8wIgC8kiqJlY_asSYq
# Filename template; {serial} is replaced with the S.N. column value.
DUES_PDF_FILENAME_TEMPLATE=All Letters_{serial}.pdf
# Default Meta template name (must be approved with header type DOCUMENT, language hi)
DUES_TEMPLATE_NAME=gunayatan_due_letter_hi
DUES_TEMPLATE_LANG=hi
# UTILITY or MARKETING (drives whether MM Lite endpoint is used)
DUES_TEMPLATE_CATEGORY=UTILITY
# How fast to hit Drive API + WhatsApp /media for the per-recipient stage step (req/sec).
# Default 3 stays well under Drive's per-user quota and WhatsApp's media-upload throttle.
DUES_STAGING_RPS=3
# How long a WhatsApp media_id is treated as valid before we re-upload (days, <=30)
DUES_MEDIA_TTL_DAYS=29
# After a webhook 'failed' status, wait this long before advancing the fallback chain
DUES_FAILED_RETRY_DELAY_MIN=10
# If a message stays in 'sent' (never reaches 'delivered') for this long, treat as
# undelivered and advance the chain (WhatsApp -> Phone -> Alternate).
DUES_STUCK_UNDELIVERED_MIN=120
# How often the deferred retry worker scans for retry candidates
DUES_DEFERRED_RETRY_INTERVAL_SEC=60
